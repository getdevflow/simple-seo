    <script>
        $(document).on('change', '#seo-404-select-all', function () {
            $('.seo-404-checkbox').prop('checked', this.checked);
        });

        $(document).on('click', '#seo-404-bulk-apply', function () {

            var action = $('#seo-404-bulk-selector').val();

            if (!action) {
                $('#bulk404ModalTitle').text('Bulk Action Required');
                $('#bulk404ModalMessage').text(
                    'Please select a bulk action before continuing.'
                );

                $('#bulk404ModalConfirm').hide();

                $('#bulk404Modal').modal('show');

                return;
            }

            var ids = [];

            $('.seo-404-checkbox:checked').each(function () {
                ids.push($(this).val());
            });

            if (!ids.length) {
                $('#bulk404ModalTitle').text('No Items Selected');
                $('#bulk404ModalMessage').text(
                    'Please select at least one 404 entry.'
                );

                $('#bulk404ModalConfirm').hide();

                $('#bulk404Modal').modal('show');

                return;
            }

            $('#seo-404-bulk-action').val(action);
            $('#seo-404-bulk-ids').val(ids.join(','));

            var actionLabel = action.charAt(0).toUpperCase() + action.slice(1);

            $('#bulk404ModalTitle').text(actionLabel + ' 404 Entries');

            $('#bulk404ModalMessage').text(
                'Apply "' + actionLabel + '" to '
                + ids.length
                + ' selected entr'
                + (ids.length === 1 ? 'y?' : 'ies?')
            );

            $('#bulk404ModalConfirm')
                .show()
                .removeClass('btn-danger btn-warning btn-success btn-primary');

            switch (action) {
                case 'delete':
                    $('#bulk404ModalConfirm').addClass('btn-danger');
                    break;

                case 'ignore':
                    $('#bulk404ModalConfirm').addClass('btn-warning');
                    break;

                case 'restore':
                    $('#bulk404ModalConfirm').addClass('btn-success');
                    break;

                default:
                    $('#bulk404ModalConfirm').addClass('btn-primary');
            }

            $('#bulk404Modal').modal('show');
        });

        $(document).on('click', '#bulk404ModalConfirm', function () {
            $('#bulk404Modal').modal('hide');
            $('#seo-404-bulk-form').submit();
        });
    </script>
