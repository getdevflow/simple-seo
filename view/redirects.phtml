    <script>
        $(document).on('change', '#seo-redirect-select-all', function () {
            $('.seo-redirect-checkbox').prop('checked', this.checked);
        });

        $(document).on('click', '#seo-redirect-bulk-apply', function () {
            var action = $('#seo-redirect-bulk-selector').val();

            if (!action) {
                $('#bulkRedirectModalTitle').text('Bulk Action Required');
                $('#bulkRedirectModalMessage').text(
                    'Please select a bulk action before continuing.'
                );

                $('#bulkRedirectModalConfirm').hide();

                $('#bulkRedirectModal').modal('show');

                return;
            }

            var ids = [];

            $('.seo-redirect-checkbox:checked').each(function () {
                ids.push($(this).val());
            });

            if (!ids.length) {
                $('#bulkRedirectModalTitle').text('No Redirects Selected');
                $('#bulkRedirectModalMessage').text(
                    'Please select at least one redirect.'
                );

                $('#bulkRedirectModalConfirm').hide();

                $('#bulkRedirectModal').modal('show');

                return;
            }

            $('#seo-redirect-bulk-action').val(action);
            $('#seo-redirect-bulk-ids').val(ids.join(','));

            var actionLabel = action.charAt(0).toUpperCase() + action.slice(1);

            $('#bulkRedirectModalTitle').text(actionLabel + ' Redirects');

            $('#bulkRedirectModalMessage').text(
                'Apply "' + actionLabel + '" to '
                + ids.length
                + ' selected redirect'
                + (ids.length === 1 ? '?' : 's?')
            );

            $('#bulkRedirectModalConfirm')
                .show()
                .removeClass('btn-danger btn-warning btn-success btn-primary');

            switch (action) {
                case 'delete':
                    $('#bulkRedirectModalConfirm').addClass('btn-danger');
                    break;

                case 'disable':
                    $('#bulkRedirectModalConfirm').addClass('btn-warning');
                    break;

                case 'enable':
                    $('#bulkRedirectModalConfirm').addClass('btn-success');
                    break;

                default:
                    $('#bulkRedirectModalConfirm').addClass('btn-primary');
            }

            $('#bulkRedirectModal').modal('show');
        });

        $(document).on('click', '#bulkRedirectModalConfirm', function () {
            $('#bulkRedirectModal').modal('hide');
            $('#seo-redirect-bulk-form').submit();
        });
    </script>
<?php }); ?>
