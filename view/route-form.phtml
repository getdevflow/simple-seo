<?php

use App\Application\Devflow;
use App\Shared\Services\Registry;

use function App\Shared\Helpers\admin_url;
use function Qubus\Security\Helpers\esc_attr;
use function Qubus\Security\Helpers\esc_html;
use function Qubus\Security\Helpers\esc_html__;
use function Qubus\Support\Helpers\is_null__;

$this->parent('framework::backend/layouts/admin-layout');
$this->block('backend', function ($param) {

Registry::getInstance()->{'set'}('screen_parent', 'simple-seo');
Registry::getInstance()->{'set'}('screen_child', 'simple-seo-routes');
$r = Registry::getInstance()->get('simple-seo');

$id = $param['route']->id ?? null;
$action = $id
    ? admin_url('plugin/simple-seo/routes/' . $id . '/')
    : admin_url('plugin/simple-seo/routes/create/');

$routePath = $param['route']->route_path ?? '';
$routeLabel = $param['route']->route_label ?? '';
$enabled = $param['route'] === null || (int) ($param['route']->enabled ?? 1) === 1;
?>

<form method="post" data-toggle="validator" action="<?= esc_attr($action); ?>" autocomplete="off">
    <div class="content-wrapper">
        <div class="box box-solid">
            <div class="box-header with-border">
                <i class="fa fa-route"></i>
                <h3 class="box-title"><?= esc_html__('Custom SEO Route', $r['id']); ?></h3>

                <div class="pull-right">
                <?php if (!is_null__($id)) : ?>
                    <button type="button" class="btn btn-warning" onclick="window.location = '<?= admin_url('plugin/simple-seo/routes/create');?>'"><i class="fa fa-plus"></i> <?=esc_html__('New SEO Route', $r['id']);?></button>
                    <button type="submit" class="btn btn-success"><i class="fa fa-pencil-alt"></i> <?= esc_html__('Update', $r['id']); ?></button>
                    <button type="button" class="btn btn-danger" data-toggle="modal" data-target="#deleteRouteSeo-<?= esc_attr((string) $id); ?>"><i class="fa fa-trash"></i> <?= esc_html__('Delete', $r['id']); ?></button>
                    <button type="button" class="btn btn-primary" onclick="window.location = '<?= admin_url('plugin/simple-seo/routes/');?>'"><i class="fa fa-ban"></i> <?= esc_html__('Cancel', $r['id']); ?></button>
                <?php else : ?>
                    <button type="submit" class="btn btn-success"><i class="fa fa-save"></i> <?= esc_html__('Save', $r['id']); ?></button>
                    <button type="button" class="btn btn-primary" onclick="window.location='<?= admin_url('plugin/simple-seo/routes/');?>'"><i class="fa fa-minus-circle"></i> <?= esc_html__('Cancel', $r['id']); ?></button>
                <?php endif; ?>
                </div>
            </div>
        </div>

        <!-- Main content -->
        <section class="content">

            <?= Devflow::$PHP->flash->display(); ?>

            <div class="row">
                <!-- left column -->
                <div class="col-md-9">
                    <?php $this->insert('plugin::SimpleSeo/view/partial/seo-tabs', [
                        'type' => $param['type'] ?? 'route',
                        'fieldPrefix' => $param['fieldPrefix'] ?? 'seo',
                        'seo' => $param['seo'] ?? [],
                        'previewUrl' => $param['previewUrl'] ?? '',
                        'entity' => $param['entity'] ?? null,
                    ]);?>
                </div>

                <div class="col-md-3">
                    <div class="box box-primary">
                        <div class="box-header with-border">
                            <h3 class="box-title">Route</h3>
                        </div>

                        <div class="box-body">
                            <input type="hidden" name="enabled" value="0">

                            <div class="form-group">
                                <label>Route Path</label>
                                <input type="text"
                                   id="seo_route_path"
                                   name="route_path"
                                   class="form-control js-seo-route-path"
                                   value="<?= esc_attr((string) $routePath); ?>"
                                   placeholder="/custom-route/"
                                   required>
                            </div>

                            <div class="form-group">
                                <label>Label</label>
                                <input type="text"
                                   name="route_label"
                                   class="form-control"
                                   value="<?= esc_attr((string) $routeLabel); ?>"
                                   placeholder="Custom Route">
                            </div>

                            <div class="checkbox">
                                <label>
                                    <input type="checkbox"
                                       name="enabled"
                                       value="1"
                                        <?= $enabled ? 'checked' : ''; ?>>
                                    Enabled
                                </label>
                            </div>
                        </div>
                    </div>

                    <?php $this->insert('plugin::SimpleSeo/view/partial/seo-side', [
                        'type' => $param['type'] ?? 'route',
                        'fieldPrefix' => $param['fieldPrefix'] ?? 'seo',
                        'seo' => $param['seo'] ?? [],
                        'previewUrl' => $param['previewUrl'] ?? '',
                        'entity' => $param['entity'] ?? null,
                    ]);?>
                </div>
            </div>
        </section>
    </div>
</form>

    <?php if (!is_null__($id)) : ?>
    <div class="modal fade" id="deleteRouteSeo-<?= esc_attr((string) $id); ?>" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post"
                      action="<?= esc_attr(admin_url('plugin/simple-seo/routes/delete/')); ?>"
                      class="modal-content">
                    <input type="hidden" name="id" value="<?= esc_attr((string) $id); ?>">

                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                        <h4 class="modal-title">Delete Custom Route SEO</h4>
                    </div>

                    <div class="modal-body">
                        Delete SEO settings for
                        <code><?= esc_html((string) $routePath); ?></code>?
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <?php endif; ?>


<?php }); ?>
