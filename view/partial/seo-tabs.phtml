$uid = uniqid('seo_', false);
$idFacebook = $uid . '_facebook_image';
$idTwitter = $uid . '_twitter_image';
$previewUrl = $seo['canonical_url'] ?? '';

if ($previewUrl === '' && $entity !== false) {
    if ($type === 'content') {
        $previewUrl = !empty($entity->relativeUrl)
            ? site_url($entity->relativeUrl)
            : site_url();
    }

    if ($type === 'product') {
        $previewUrl = !empty($entity->relativeUrl)
            ? site_url($entity->relativeUrl)
            : site_url('/product/' . trim((string) $entity->slug, '/') . '/');
    }

    if ($type === 'page') {
        $previewUrl = !empty($entity->relativeUrl)
            ? site_url($entity->relativeUrl)
            : site_url($entity->route);
    }
}

if ($previewUrl === '') {
    $previewUrl = site_url();
}

$schemaJson = $seo['schema_json'] ?? '';

if ($schemaJson !== '') {
    $decoded = json_decode($schemaJson, true);

    if (json_last_error() === JSON_ERROR_NONE) {
        $schemaJson = json_encode(
            $decoded,
            JSON_PRETTY_PRINT
            | JSON_UNESCAPED_SLASHES
            | JSON_UNESCAPED_UNICODE
        );
    }
}

$fieldPrefix = $fieldPrefix ?? 'content_field';

$seoFieldPrefix = $fieldPrefix === 'seo'
    ? 'seo'
    : $fieldPrefix . '[seo]';
?>

