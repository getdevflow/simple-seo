<script>
    (function ($) {
        $(document).on('click', '.js-seo-elfinder', function (e) {
            e.preventDefault();

            var target = $($(this).data('target'));
            var finder = $('<div class="seo-elfinder-dialog"></div>');

            finder.dialog({
                title: 'Select Image',
                modal: true,
                width: 920,
                height: 550,
                closeOnEscape: true,
                destroyOnClose: true,
                close: function () {
                    $(this).dialog('destroy').remove();
                },
                open: function () {
                    finder.elfinder({
                        url: '<?=admin_url('connector');?>',
                        lang: 'en',
                        commandsOptions: {
                            getfile: {
                                onlyURL: false,
                                multiple: false,
                                folders: false,
                                oncomplete: "destroy"
                            }
                        },
                        getFileCallback: function (file, fm) {
                            if ($.isArray(file)) {
                                file = file[0];
                            }

                            var url = file && file.url ? file.url : '';

                            if (url !== '') {
                                target.val(url).trigger('change');
                            }

                            finder.dialog('close');
                        }
                    });
                }
            });
        });
    })(jQuery);
</script>


